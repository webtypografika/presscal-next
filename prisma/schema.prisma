// PressCal Pro — Prisma Schema
// Common fields in columns, type-specific data in JSON specs

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH (NextAuth.js) ───
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  orgId         String?
  org           Org?      @relation(fields: [orgId], references: [id])
  accounts        Account[]
  sessions        Session[]
  dismissedEmails DismissedEmail[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── ORGANIZATION (multi-tenant ready) ───
model Org {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Λογότυπο
  logo         String?  // URL path to logo image

  // Φορολογικά στοιχεία
  legalName    String?  // Επωνυμία
  afm          String?  // ΑΦΜ
  doy          String?  // ΔΟΥ
  gemh         String?  // ΓΕΜΗ
  profession   String?  // Επάγγελμα / Δραστηριότητα
  address      String?  // Διεύθυνση
  city         String?  // Πόλη
  postalCode   String?  // ΤΚ
  phone        String?  // Τηλέφωνο
  email        String?  // Email
  website      String?  // Website

  // Συνδρομή
  plan         String   @default("free")  // 'free' | 'starter' | 'pro' | 'enterprise'
  planExpiry   DateTime?

  // API Keys (encrypted in production)
  apiElorus    String?  // Elorus API key
  apiGmail     String?  // Gmail App Password or OAuth token
  apiGemini    String?  // Gemini API key (override .env)
  apiFilehelper String? // File Helper API key

  // Elorus integration settings
  elorusOrgId          String?  // Elorus organization ID
  elorusOrgSlug        String?  // e.g. "typografika" for URLs
  elorusOrgName        String?  // Organization display name
  elorusDefaultDocType String?  // Document type ID
  elorusDefaultTaxId   String?  // Tax ID (e.g. 24% ΦΠΑ)
  elorusDefaultMyData  String?  // MyDATA doc type e.g. "2.1"
  elorusDefaultClassCat String? // e.g. "category1_3"
  elorusDefaultClassType String? // e.g. "E3_561_001"
  elorusDocTypes       Json?    // Cached: [{id,title,category}]
  elorusTaxes          Json?    // Cached: [{id,title,percentage}]

  // Quote terms & conditions (supports numbered sections in JSON)
  quoteTerms   Json?    // [{title: string, text: string}]

  // Job stages (customizable)
  jobStages    Json?    // [{id: string, label: string, icon: string, color: string}]

  // Job folder settings
  jobFolderRoot String?  // Global root path e.g. "D:\\Εργασίες"

  // Courier integration
  courierProvider      String?  // 'nexday' (future: 'acs', 'speedex' etc.)
  courierApiKey        String?  // Bearer token
  courierSenderName    String?
  courierSenderPhone   String?
  courierSenderAddress String?
  courierSenderCity    String?
  courierSenderZip     String?

  // AADE credentials (for AFM lookup)
  aadeUsername  String?
  aadePassword  String?
  aadeAfm       String?  // Company's own ΑΦΜ for AADE calls

  machines         Machine[]
  postpressMachines PostpressMachine[]
  users            User[]
  materials        Material[]
  consumables      Consumable[]
  profiles         Profile[]
  companies        Company[]
  contacts         Contact[]
  customers        Customer[]  // DEPRECATED — kept for migration
  quotes           Quote[]
  products         Product[]
  fileLinks        FileLink[]
  plateOrders      PlateOrder[]
  calendarEvents   CalendarEvent[]
}

// ─── MACHINES (Digital / Offset / Plotter) ───
model Machine {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  name      String
  cat       String   // 'digital' | 'offset' | 'plotter'
  notes     String   @default("")

  // Common dimensions (mm)
  maxLS     Float?   // max long side
  maxSS     Float?   // max short side
  minLS     Float?   // min long side
  minSS     Float?   // min short side

  // Margins (mm)
  marginTop    Float?
  marginBottom Float?
  marginLeft   Float?
  marginRight  Float?

  // All type-specific fields in JSON
  // Digital: click costs, toner yields, drums, speed zones, consumables...
  // Offset: towers, inks, chemicals, plates, rollers, depreciation...
  // Plotter: speed modes, ink costs, lamp life...
  specs     Json     @default("{}")

  // Relations
  consumables Consumable[]

  // Soft delete
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, cat])
  @@index([orgId, deletedAt])
}

// ─── POSTPRESS MACHINES (Guillotine / Laminator / Binder / Folder / etc.) ───
model PostpressMachine {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  name      String
  cat       String   // 'sheet' | 'roll'
  subtype   String   // 'guillotine' | 'lam_roll' | 'lam_sheet' | 'gathering' |
                     // 'fold' | 'spiral' | 'glue_bind' | 'staple' | 'custom'
  notes     String   @default("")

  // Common cost fields
  setupCost    Float?
  speed        Float?
  minCharge    Float?
  hourlyRate   Float?

  // All subtype-specific fields in JSON
  // Guillotine: cut_width, lift_h, blade_life, secs_per_cut...
  // Laminator: film_type, tech, max_w, seal_margin, linked_films...
  // Binder: glue_type, clamps, max_spine, cover_cost...
  // Folder: plates, max_speed, max_w...
  // etc.
  specs     Json     @default("{}")

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, subtype])
  @@index([orgId, deletedAt])
}

// ─── MATERIALS (Papers / Films) ───
model Material {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  name      String
  cat       String   // 'sheet' | 'roll' | 'film'
  groupName String?  // 'Coated', 'Uncoated', 'Special', 'Kraft'...
  subtype   String?  // 'velvet', 'gloss', 'silk', 'munken'...
  supplier  String?  // 'Mondi', 'Antalis', 'Graphcom'...
  supplierEmail String?
  notes     String   @default("")

  // Dimensions
  width     Float?   // mm — short side (SS)
  height    Float?   // mm — long side (LS), null for rolls
  thickness Float?   // gsm for paper, microns for film
  grain     String?  // 'long' | 'short' | 'none' — fiber direction

  // Roll-specific
  rollLength Float?  // meters (for rolls)

  // Cost & pricing
  costPerUnit  Float?  // € per sheet/meter/piece
  markup       Float?  // markup % for sell price
  sellPerUnit  Float?  // € sell price (calculated or manual)
  unit         String  @default("φύλλο") // 'φύλλο', 'μέτρο', 'τεμ'

  // Stock
  stock        Float?  // current quantity
  stockTarget  Float?  // target max stock
  stockAlert   Float?  // low stock alert threshold

  // Type-specific in JSON (NCR layers, film tech, etc.)
  specs     Json     @default("{}")

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, cat])
  @@index([orgId, groupName])
  @@index([orgId, supplier])
  @@index([orgId, deletedAt])
}

// ─── CONSUMABLES (Inks / Toner / Drums / Plates / Blankets / Chemicals) ───
model Consumable {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  name      String
  conType   String   // 'ink' | 'toner' | 'drum' | 'developer' | 'plate' | 'blanket' |
                     // 'chemical' | 'varnish' | 'fuser' | 'belt' | 'waste' | 'corona' | 'other'
  conModule String   // 'offset' | 'digital' | 'shared'
  color     String?  // 'cyan' | 'magenta' | 'yellow' | 'black' | 'white' | 'clear' | 'gold' | 'silver'
  groupName String?  // 'Process', 'OEM', 'Compatible'...
  supplier  String?
  supplierEmail String?
  notes     String   @default("")

  // Linked machine (optional — null = available to all)
  machineId String?
  machine   Machine? @relation(fields: [machineId], references: [id])

  // Cost
  unit         String   @default("τεμ") // 'kg' | 'lt' | 'τεμ' | 'set'
  unitSize     Float?   // package size (e.g., 1kg, 5lt)
  costPerUnit  Float?   // € per package
  costPerBase  Float?   // calculated: € per kg/lt/piece

  // Yield (for toner, drum, fuser, belt, etc.)
  yieldPages   Float?   // pages at 5% coverage

  // Stock
  stock        Float?
  stockTarget  Float?
  stockAlert   Float?

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, conType])
  @@index([orgId, conModule])
  @@index([orgId, machineId])
  @@index([orgId, deletedAt])
}

// ─── PLATE ORDERS (Platemaker service & blank plate material) ───
model PlateOrder {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  orderType String   // 'platemaker_service' | 'plate_material'
  status    String   @default("sent") // 'draft' | 'sent' | 'received' | 'cancelled'

  // Supplier
  supplierName  String
  supplierEmail String?

  // Items: [{name, plateSize, qty, color}] or [{name, size, qty}]
  items     Json     @default("[]")

  // Plate service: job info + PDF
  jobDescription String?
  pdfFileName    String?

  // Cost
  totalCost Float?
  notes     String   @default("")

  sentAt     DateTime?
  receivedAt DateTime?
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orgId, status])
  @@index([orgId, orderType])
  @@index([orgId, deletedAt])
}

// ─── SALES PROFILES (Markups & Charges) ───
model Profile {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  name      String
  isDefault Boolean  @default(false)
  notes     String   @default("")

  // Markup percentages
  paperMarkup      Float   @default(50)   // %
  printMarkup      Float   @default(100)  // %
  guillotineMarkup Float   @default(100)  // %
  lamMarkup        Float   @default(100)  // %
  bindingMarkup    Float   @default(100)  // %

  // Min charges (€)
  minChargePrint      Float?
  minChargeGuillotine Float?
  minChargeLam        Float?
  minChargeBinding    Float?

  // Extra charges
  specs     Json     @default("{}")  // per-product overrides, custom charges

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

// ─── GLOBAL PRODUCTS ───
model Product {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  name      String
  archetype String   // 'single_leaf' | 'pad' | 'booklet' | 'perfect_bound' | 'die_cut' | 'custom'
  notes     String   @default("")

  // Archetype-specific fields
  pages          Int?     // booklet pages
  sheetsPerPad   Int?     // pad sheets
  bodyPages      Int?     // perfect bound body pages
  customMult     Float?   // custom multiplier

  // Offset profit settings
  offset    Json     @default("{}")
  // Digital profit settings
  digital   Json     @default("{}")
  // Finishing settings
  finishing Json     @default("[]")

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, archetype])
  @@index([orgId, deletedAt])
}

// ─── CUSTOMERS (DEPRECATED — kept for migration) ───
model Customer {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  name      String
  company   String?
  email     String?
  phone     String?
  mobile    String?
  afm       String?
  doy       String?
  elorusContactId String?
  address   String?
  city      String?
  zip       String?
  notes     String   @default("")
  folderPath String?
  contacts  Json     @default("[]")
  tags      String[] @default([])

  quotes    Quote[]    @relation("CustomerQuotes")
  fileLinks FileLink[] @relation("CustomerFileLinks")

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, deletedAt])
}

// ─── COMPANIES (billing entities) ───
model Company {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  name      String            // Επωνυμία
  afm       String?           // ΑΦΜ
  doy       String?           // ΔΟΥ
  address   String?
  city      String?
  zip       String?
  phone     String?           // Company phone
  email     String?           // Company general email
  website   String?
  notes     String   @default("")
  tags      String[] @default([])

  folderPath        String?   // Shared folder for this company
  elorusContactId   String?   // Elorus contact (company-level)

  // Relations
  companyContacts CompanyContact[]
  quotes          Quote[]
  fileLinks       FileLink[]
  calendarEvents  CalendarEvent[]

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, deletedAt])
}

// ─── CONTACTS (people) ───
model Contact {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  name      String
  email     String?
  phone     String?
  mobile    String?
  notes     String   @default("")
  tags      String[] @default([])

  // employee | designer | freelancer | broker | contact
  role      String   @default("contact")

  // Relations
  companyContacts CompanyContact[]
  quoteRecipients QuoteRecipient[]
  calendarEvents  CalendarEvent[]

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, email])
  @@index([orgId, deletedAt])
}

// ─── COMPANY ↔ CONTACT (N:M) ───
model CompanyContact {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  role      String   @default("employee")  // role within this company
  isPrimary Boolean  @default(false)       // primary contact for this company

  createdAt DateTime @default(now())

  @@unique([companyId, contactId])
  @@index([contactId])
}

// ─── QUOTE RECIPIENTS ───
model QuoteRecipient {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id])

  type      String   @default("to")  // 'to' | 'cc'

  @@unique([quoteId, contactId])
  @@index([quoteId])
}

// ─── QUOTES ───
model Quote {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  number    String   // QT-2026-0001
  status    String   @default("draft") // draft, sent, approved, partial, rejected, completed, cancelled

  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])

  // DEPRECATED — kept for migration
  customerId String?
  customer   Customer? @relation("CustomerQuotes", fields: [customerId], references: [id])

  title       String?
  description String?
  notes       String?

  // Items stored as JSON array (QuoteLineItem[])
  items       Json    @default("[]")

  // Totals
  subtotal    Float   @default(0)
  vatRate     Float   @default(24)
  vatAmount   Float   @default(0)
  grandTotal  Float   @default(0)
  totalCost   Float   @default(0)
  totalProfit Float   @default(0)

  // Job board
  jobStage          String?   // 'files' | 'printing' | 'cutting' | 'finishing' | 'delivery'
  jobStageUpdatedAt DateTime?
  jobFolderPath     String?   // Resolved local path (set on approval)
  deadline          DateTime?
  jobPriority       String?   // 'normal' | 'urgent' | 'rush'
  jobNotes          String?

  // Email
  threadId     String?
  linkedEmails String[] @default([])

  // Approval
  approvalToken    String?
  approvedAt       DateTime?
  approvedItems    String[] @default([])
  rejectedItems    String[] @default([])
  partialApproval  Boolean  @default(false)
  customerNotes    String?

  // Invoicing
  elorusInvoiceId  String?
  elorusInvoiceUrl String?
  elorusContactId  String?

  // Courier
  courierVoucherId  String?
  courierProvider   String?   // 'nexday'
  courierStatus     String?
  courierStatusAt   DateTime?

  // Company profile snapshot (for approval page branding)
  companyProfile   Json?

  // Dates
  date        DateTime @default(now())
  sentAt      DateTime?
  completedAt DateTime?

  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fileLinks       FileLink[]
  quoteRecipients QuoteRecipient[]
  calendarEvents  CalendarEvent[]

  @@index([orgId, status])
  @@index([orgId, companyId])
  @@index([orgId, deletedAt])
  @@unique([orgId, number])
}

// ─── DISMISSED EMAILS (hidden from dashboard, not deleted from Gmail) ───
model DismissedEmail {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gmailId   String   // Gmail message ID
  createdAt DateTime @default(now())

  @@unique([userId, gmailId])
  @@index([userId])
}

// ─── FILE LINKS (File Helper integration) ───
model FileLink {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  // File info
  fileName  String
  filePath  String
  fileType  String     // extension: pdf, psd, ai, etc.
  fileSize  Int
  source    String     // 'local' | 'dropbox'

  // Links (one of)
  quoteId    String?
  quote      Quote?    @relation(fields: [quoteId], references: [id])
  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id])

  // DEPRECATED — kept for migration
  customerId String?
  customer   Customer? @relation("CustomerFileLinks", fields: [customerId], references: [id])

  // Metadata
  thumbnail       String?  // base64 thumbnail data
  preflightStatus String?  // 'pass' | 'warning' | 'error'
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([quoteId])
  @@index([companyId])
}

// ─── CALENDAR EVENTS ───
model CalendarEvent {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])

  title     String
  type      String   @default("appointment")  // 'appointment' | 'task' | 'deadline' | 'reminder'
  startAt   DateTime
  endAt     DateTime?
  allDay    Boolean  @default(false)
  color     String?

  // Links (optional)
  quoteId   String?
  quote     Quote?   @relation(fields: [quoteId], references: [id])
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  notes     String   @default("")
  completed Boolean  @default(false)

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, startAt])
  @@index([quoteId])
  @@index([companyId])
}
